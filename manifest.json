{
  "manifest_version": 3,
  "name": "DistractionFree",
  "version": "2.0.0",
  "description": "Block distracting feeds, sidebars, badges, and upsells on LinkedIn.",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["*://*.linkedin.com/*", "http://127.0.0.1:9876/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "web_accessible_resources": [{
    "resources": ["data/quotes.js"],
    "matches": ["*://*.linkedin.com/*"]
  }],
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["data/quotes.js", "content/shared.js", "content/linkedin.js"],
      "run_at": "document_start"
    }
  ]
}
